,null,{\"mode\":\"split-right\"}]}]]}],[\"$\",\"div\",null,{\"className\":\"hidden md:block relative\",\"style\":{\"minHeight\":\"180px\"},\"children\":[[\"$\",\"div\",null,{\"className\":\"absolute inset-0\",\"style\":{\"clipPath\":\"polygon(0 0, 60% 0, 52% 100%, 0 100%)\"},\"children\":[\"$\",\"$L28\",null,{\"siteName\":\"NovelDex\",\"shareWidgetText\":\"Share our site with your friends!\",\"socialWidgetText\":\"Join Our Community\",\"discordUrl\":\"https://discord.gg/DTFpPwEZbD\",\"twitterUrl\":\"\",\"discordEnabled\":true,\"twitterEnabled\":false,\"showSocialWidget\":true,\"compact\":true,\"discordRequiresLogin\":true}]}],[\"$\",\"div\",null,{\"className\":\"absolute inset-0\",\"style\":{\"clipPath\":\"polygon(58% 0, 100% 0, 100% 100%, 50% 100%)\"},\"children\":[\"$\",\"$L29\",null,{\"mode\":\"split-right\"}]}],[\"$\",\"div\",null,{\"className\":\"absolute inset-0 pointer-events-none z-10\",\"style\":{\"background\":\"linear-gradient(to bottom right, transparent 49.3%, rgba(255,255,255,0.12) 49.3%, rgba(255,255,255,0.12) 50.7%, transparent 50.7%)\"}}]]}]]}]}]\n"])</script><script>self.__next_f.push([1,"2b:T4a3,The story begins with a completely ordinary individual who is admitted to an academy specializing in Hunters and Awakened people. However, they discover they are unawakened and possess no supernatural ability, making them a target of ridicule.\r\n\r\nThis person suddenly awakens a unique and unprecedented ability: the power to \"Enter Fictional Works\" or \"Creative Works\" that they view.\r\n\r\nInitially, they use this power chaotically and experimentally, beginning with entry into short, specific entertainment works. Through these experiences, they successfully upgrade their physical stats and acquire new skills and abilities.\r\n\r\nTheir quiet life transforms into a series of challenges as they are forced to use their new power to navigate various worlds (whether fantasy, martial arts, or game worlds) with the goals of:\r\n\r\nGaining power from these different realms.\r\n\r\nBuilding an exceptional network of relationships.\r\n\r\nSurviving the dangers lurking in every fictional work they enter.\r\n\r\nThus, this once-ordinary person becomes the owner of the strangest and most powerful ability of all, relying on their foresight into the rules and mechanics of every creative work they jump into."])</script><script>self.__next_f.push([1,"e:[\"$\",\"div\",null,{\"children\":[\"$\",\"$L2a\",null,{\"initialSlides\":[{\"id\":\"cmlngn05o000nwq6h9idb5bu4\",\"slug\":\"murim-psychopath\",\"urlSlug\":\"murim-psychopath\",\"title\":\"Murim Psychopath\",\"description\":\"[Welcome to the world of true powerhouses, Murim Online.]\\r\\n[The device is malfunctioning, and you have failed to log out.]\\r\\n[Would you like to try disconnecting again?]\\r\\n[Yes or No]\\r\\nWhen he tried to return to the virtual reality,\\r\\n\\r\\nthe place he logged into was the ‘real Murim’.\\r\\n\\r\\nA rare psychopath, dropped into Murim by the Grim Reaper’s mistake.\\r\\n\\r\\nIn a Murim filled with conspiracies and malice, Dong Bong-soo, his ruthless fangs, cast their shadow.\",\"coverImage\":\"/uploads/series/2026/02/cover-512185beba7052ba74fd42c12d888ece.webp\",\"bannerImage\":\"/uploads/series/2026/02/banner-efb475d9e017fb683654a52a8a41406d.webp\",\"rating\":9.833333333333334,\"viewCount\":458002,\"type\":\"WEB_NOVEL\",\"isMature\":false,\"genres\":[{\"genre\":{\"name\":\"Action\",\"color\":\"#ef4444\",\"slug\":\"action\"}},{\"genre\":{\"name\":\"Fantasy\",\"color\":\"#8b5cf6\",\"slug\":\"fantasy\"}},{\"genre\":{\"name\":\"Mystery\",\"color\":\"#6366f1\",\"slug\":\"mystery\"}},{\"genre\":{\"name\":\"Psychological\",\"color\":\"#7c3aed\",\"slug\":\"psychological\"}},{\"genre\":{\"name\":\"Supernatural\",\"color\":\"#a855f7\",\"slug\":\"supernatural\"}},{\"genre\":{\"name\":\"Tragedy\",\"color\":\"#991b1b\",\"slug\":\"tragedy\"}},{\"genre\":{\"name\":\"Martial Arts\",\"color\":\"#f59e0b\",\"slug\":\"martial-arts\"}},{\"genre\":{\"name\":\"Wuxia\",\"color\":\"#ea580c\",\"slug\":\"wuxia\"}},{\"genre\":{\"name\":\"Xuanhuan\",\"color\":\"#c026d3\",\"slug\":\"xuanhuan\"}},{\"genre\":{\"name\":\"GameLit\",\"color\":\"#14b8a6\",\"slug\":\"gamelit\"}},{\"genre\":{\"name\":\"Seinen\",\"color\":\"#7c3aed\",\"slug\":\"seinen\"}},{\"genre\":{\"name\":\"Mature\",\"color\":\"#be123c\",\"slug\":\"mature\"}}],\"_count\":{\"chapters\":260}},{\"id\":\"cmlucnp850vh4wq2250i8ms5w\",\"slug\":\"my-girlfriend-is-already-fully-trained\",\"urlSlug\":\"my-girlfriend-is-already-fully-trained\",\"title\":\"My Girlfriend Is Already Fully Trained\",\"description\":\"\\\"I heard some bad rumors about my girlfriend, Hayoung.\\r\\n\\r\\nPffft, ey~ No way, there's no way Hayoung would do that, right?\\\"\",\"coverImage\":\"/uploads/series/2026/02/cover-2b001be355fa6b0c79626c626d7a65a6.webp\",\"bannerImage\":null,\"rating\":3.3529411764705883,\"viewCount\":346458,\"type\":\"WEB_NOVEL\",\"isMature\":false,\"genres\":[{\"genre\":{\"name\":\"Drama\",\"color\":\"#f97316\",\"slug\":\"drama\"}},{\"genre\":{\"name\":\"Adult\",\"color\":\"#9f1239\",\"slug\":\"adult\"}}],\"_count\":{\"chapters\":301}},{\"id\":\"cmli0u7sc00ljwqlrxjyqcmk0\",\"slug\":\"legendary-hero-is-an-academy-honors-student\",\"urlSlug\":\"legendary-hero-is-an-academy-honors-student\",\"title\":\"Legendary Hero is an Academy Honors Student\",\"description\":\"There were five heroes who fought against Erebos, the primordial evil that drove the world to the brink of destruction.\\r\\n\\r\\n[Brave] Aron.\\r\\n[God’s Blacksmith] Dweno.\\r\\n[The Founder of the Nebula] Luna.\\r\\n[King of Wisdom] Risinas.\\r\\nAnd lastly, me [The Hero of Beginning] Kyle.\\r\\n\\r\\nWhen I was reincarnated 5000 years later, everyone was praised as a Legendary hero.\\r\\n\\r\\n“Except me.”\\r\\n\\r\\nA gift from God that records the achievements of heroes.\\r\\n\\r\\nThe Hero Academy with Hero Records.\\r\\n\\r\\nLet’s go there and find out why.\",\"coverImage\":\"/uploads/series/2026/02/cover-e8c7cf