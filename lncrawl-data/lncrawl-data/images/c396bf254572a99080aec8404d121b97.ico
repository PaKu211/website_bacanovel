26/02/cover-91077acb3a6d9b7a52082fbcccebd340.webp\",\"/uploads/series/2026/02/cover-aef40fc0344ef26cabc0cc41a33f009b.jpg\",\"/uploads/series/2026/02/cover-6992f19f1fb7d7a2ef96af5ee27f9ad4.webp\"],\"query\":{\"tags\":[\"Pretend Lovers\",\"Contracts\",\"Marriage of Convenience\",\"Cohabitation\",\"Misunderstandings\"],\"genres\":[\"Romance\"],\"minMatches\":2,\"requireAll\":false},\"seriesCount\":29,\"viewCount\":2453,\"likeCount\":1,\"contentType\":\"NOVELS\"},{\"id\":\"cmmzkmnj200wiuvqnqcrgxon4\",\"slug\":\"gender-bender-romance\",\"name\":\"Love Knows No Gender\",\"description\":\"When your gender changes, does your heart change too? Gender-bending romance that explores love, identity, and attraction.\",\"icon\":\"🌈\",\"coverImages\":[\"/uploads/series/2026/02/cover-81eab6fd5a03dccf4c495c940bce803f.webp\",\"/uploads/series/2026/02/cover-795afbec7978f3f4e63ad633bb4f268e.webp\",\"/uploads/series/2026/02/cover-aa8bbb3c636dfdac64e4dfcc32ca7d69.webp\",\"/uploads/series/2026/04/cover-019c87bbbf97cfe4cf4edb9214fcff15.webp\"],\"query\":{\"tags\":[\"Gender Bender\",\"Female to Male\",\"Male to Female\",\"Identity Crisis\"],\"genres\":[\"Gender Bender\",\"Romance\"],\"minMatches\":3,\"requireAll\":false},\"seriesCount\":6,\"viewCount\":2208,\"likeCount\":1,\"contentType\":\"NOVELS\"},{\"id\":\"cmmzkmj5b00thuvqnk2ptmq2q\",\"slug\":\"dystopia-now\",\"name\":\"Dystopia Now\",\"description\":\"Totalitarian regimes, controlled populations, and the brave souls who dare to rebel. Dark futures that hit too close to home.\",\"icon\":\"🏗️\",\"coverImages\":[\"/uploads/series/2026/03/cover-e37d6446f908269a3878195e5ba76b34.webp\",\"/uploads/series/2026/02/cover-d9d89e76be466f0989d7e4c0078816e7.webp\",\"/uploads/series/2026/02/cover-1b63f7e5326cb7d2c5126d00fb49176e.webp\",\"/uploads/series/2026/02/cover-b031717b85e811b1824e2c9909f50c97.webp\"],\"query\":{\"tags\":[\"Dystopia\",\"Rebellion\",\"Terrorists\",\"Corruption\",\"Evil Organizations\"],\"genres\":[\"Horror\",\"Sci-Fi\"],\"minMatc