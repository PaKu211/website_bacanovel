<body class="enter-content pc-enter-content">
    <div class="enter-container">
        <div class="logo-wrapper">
            <img class="img-logo" src="/assets/images/index-logo.png">
        </div>
        
        <div id="txt1" class="txt-title txt-custom">&#xEB36;&#xEB39;&#xEB78;&#xEB70;&#xEB8A;&#xEB61;&#xEB42;&#xEB5E;&#xEB42;&#xEB3C;</div>
        <div id="txt2" class="txt-content txt-custom">&#xEB88;&#xEB83;&#xEB62;&#xEB6C;&#xEB5D;&#xEB69;&#xEB68;&#xEB3D;&#xEB48;&#xEB6F;&#xEB4A;&#xEB2C;&#xEB65;&#xEB3B;</div>
        <a href="/index/home.html"><div class="txt-enter txt-custom" id="txt3">&#xEB64;&#xEB69;&#xEB68;&#xEB3D;&#xEB2D;&#xEB37;&#xEB4E;&#xEB71;&#xEB7F;&#xEB86;</div></a>
        <div class="txt-content txt-custom" id="txt4">&#xEB6F;&#xEB45;&#xEB4C;&#xEB6A;&#xEB87;&#xEB67;&#xEB79;&#xEB2A;&#xEB74;</div>
        <div class="txt-content txt-custom" id="txt5">&#xEB6A;&#xEB87;&#xEB56;&#xEB55;&#xEB2E;&#xEB41;&#xEB8F;&#xEB3A;&#xEB37;&#xEB6F;&#xEB31;&#xEB5F;&#xEB68;&#xEB85;&#xEB73;&#xEB3E;&#xEB2F;&#xEB67;&#xEB79;&#xEB8F;&#xEB3A;&#xEB63;&#xEB60;&#xEB44;&#xEB72;&#xEB84;&#xEB82;&#xEB57;&#xEB30;&#xEB6A;&#xEB87;&#xEB75;</div>
        <div class="txt-content txt-custom" id="txt6">&#xEB47;&#xEB4B;&#xEB38;&#xEB33;&#xEB34;&#xEB8D;&#xEB4F;&#xEB80;&#xEB5E;&#xEB5B;&#xEB7E;&#xEB5E;&#xEB4D;&#xEB80;&#xEB5E;&#xEB5B;&#xEB7E;&#xEB5E;&#xEB7C;&#xEB8A;&#xEB5E;&#xEB8C;&#xEB59;&#xEB66;&#xEB46;&#xEB7C;&#xEB32;&#xEB52;&#xEB67;&#xEB79;&#xEB8F;&#xEB3A;</div>
        <div class="txt-saveqr txt-custom" onclick="downloadQRCode()">
            <div class="qrcode" id="qrcodeSmall" style="width:20px; height:20px;"></div>
            <span class="txt-custom" id="txt7">&#xEB44;&#xEB58;&#xEB2B;&#xEB8E;&#xEB77;</span>
        </div>
        <div class="txt-content txt-custom" id="txt8">&#xEB81;&#xEB3F;&#xEB4E;&#xEB6B;&#xEB7F;&#xEB86;&#xEB8B;&#xEB6D;&#xEB51;&#xEB2C;&#xEB6A;&#xEB87;&#xEB37;&#xEB6F;&#xEB41;&#xEB89;&#xEB49;&#xEB40;&#xEB50;&#xEB6E;&#xEB43;&#xEB54;&#xEB2A;&#xEB76;&#xEB37;</div>
        <div class="txt-content txt-custom" id="txt9">&#xEB35;&#xEB7A;&#xEB2A;&#xEB76;&#xEB5A;&#xEB7B;&#xEB7D;&#xEB5C;&#xEB6A;&#xEB87;&#xEB53;</div>
    </div>

    <div id="qrcode" style="width:200px; height:200px; position: absolute; bottom: 0; left: 0; z-index: -1; visibility: hidden;"></div>

    <script>
        var host = document.domain;
        var qrcode = new QRCode(document.getElementById("qrcode"), {
            width : 200,
            height : 200
        });
        qrcode.makeCode(host)

        //qrcodeSmall
        var qrcodeSmall = new QRCode(document.getElementById("qrcodeSmall"), {
            width : 20,
            height : 20
        });
        qrcodeSmall.makeCode(host)

        function downloadQRCode () {
            var img = document.getElementById("qrcode").querySelector('img')
            var link = document.createElement("a")
            link.download = 'qrcode.png'
            link.href = img.src
            link.click()
        }
    </script>
</body>

</html>
